# ============================================================
#  Micro BI — production configuration (beta)
#  Copy to .env and fill in values marked [CHANGE].
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=microbi
# [CHANGE] strong password
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=microbi
DATABASE_URL=postgresql+asyncpg://microbi:CHANGE_ME_strong_password@postgres:5432/microbi
# ^ password must be identical to POSTGRES_PASSWORD above

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
# [CHANGE] generate: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Internal service token (worker -> backend DuckDB HTTP) ---
# [CHANGE]
SERVICE_TOKEN=CHANGE_ME_run_openssl_rand_hex_32

# --- DuckDB ---
DUCKDB_PATH=/data/micro_bi.duckdb

# --- Aplikacja ---
APP_NAME=Micro BI
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# [CHANGE] Public address under which you expose Micro BI.
# Used in report-sharing links and in emails.
# Examples: http://192.168.1.50:8080  or  https://bi.yourcompany.com
APP_PUBLIC_URL=http://CHANGE_ME:8080

# CORS — in prod, frontend and API are on the same origin, so usually
# it's enough to enter the same address as APP_PUBLIC_URL here.
CORS_ORIGINS=http://CHANGE_ME:8080

# --- Activation server (licensing) ---
# [REQUIRED] Address of the real, publicly accessible activation server.
# Example: https://activation.microbi.app/api/v1
ACTIVATION_SERVER_URL=https://activation.microbi.app/api/v1

# --- Port under which the interface (nginx) is exposed ---
HTTP_PORT=8080

# --- Image tag (which version to pull from GHCR) ---
MICROBI_TAG=beta